<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="seed_account_ivan" author="DLinnik">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM account WHERE username = 'ivanivanov'
            </sqlCheck>
        </preConditions>

        <insert tableName="account">
            <column name="username" value="ivan"/>
            <column name="full_name" value="Ivan Ivanov"/>
            <column name="date_of_birth" valueDate="2001-05-10"/>
            <column name="balance" valueNumeric="1000.00"/>
        </insert>

        <rollback>
            <delete tableName="account">
                <where>username = 'ivan'</where>
            </delete>
        </rollback>
    </changeSet>

