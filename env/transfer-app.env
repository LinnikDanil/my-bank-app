SERVER_PORT=8084
ACCOUNT_BASE_URL=http://account-app:8082
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
NOTIFICATION_TOPIC=notification-events
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=10
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true
RESILIENCE4J_ACCOUNT_CB_SLIDING_WINDOW_TYPE=COUNT_BASED
RESILIENCE4J_ACCOUNT_CB_SLIDING_WINDOW_SIZE=10
RESILIENCE4J_ACCOUNT_CB_MINIMUM_NUMBER_OF_CALLS=5
RESILIENCE4J_ACCOUNT_CB_PERMITTED_CALLS_HALF_OPEN=3
RESILIENCE4J_ACCOUNT_CB_WAIT_DURATION_OPEN_STATE=10s
RESILIENCE4J_ACCOUNT_CB_FAILURE_RATE_THRESHOLD=50
RESILIENCE4J_NOTIFICATION_CB_SLIDING_WINDOW_TYPE=COUNT_BASED
RESILIENCE4J_NOTIFICATION_CB_SLIDING_WINDOW_SIZE=10
RESILIENCE4J_NOTIFICATION_CB_MINIMUM_NUMBER_OF_CALLS=5
RESILIENCE4J_NOTIFICATION_CB_PERMITTED_CALLS_HALF_OPEN=3
RESILIENCE4J_NOTIFICATION_CB_WAIT_DURATION_OPEN_STATE=10s
RESILIENCE4J_NOTIFICATION_CB_FAILURE_RATE_THRESHOLD=50
RESILIENCE4J_ACCOUNT_RETRY_MAX_ATTEMPTS=3
RESILIENCE4J_ACCOUNT_RETRY_WAIT_DURATION=300ms
RESILIENCE4J_NOTIFICATION_RETRY_MAX_ATTEMPTS=3
RESILIENCE4J_NOTIFICATION_RETRY_WAIT_DURATION=300ms
TRANSFER_JWT_ISSUER_URI=http://localhost:8080/realms/my-bank-realm
TRANSFER_JWT_JWK_SET_URI=http://keycloak:8080/realms/my-bank-realm/protocol/openid-connect/certs
TRANSFER_CLIENT_ID=transfer-service
TRANSFER_CLIENT_SECRET=transfer-secret
TRANSFER_OAUTH2_TOKEN_URI=http://keycloak:8080/realms/my-bank-realm/protocol/openid-connect/token
TRANSFER_OUTBOUND_OAUTH2_REGISTRATION_ID=transfer-service-client
